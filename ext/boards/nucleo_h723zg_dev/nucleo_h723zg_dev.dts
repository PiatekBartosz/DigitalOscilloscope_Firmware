/dts-v1/;
#include <st/h7/stm32h723Xg.dtsi>
#include <st/h7/stm32h723zgtx-pinctrl.dtsi>
#include "arduino_r3_connector.dtsi"
#include <zephyr/dt-bindings/input/input-event-codes.h>

/*
 * WARNING:
 * JP6 and SB72 must be ON when using Ethernet.
 */

/ {
	model = "STMicroelectronics STM32H723ZG-NUCLEO board";
	compatible = "st,stm32h723zg-nucleo";

	chosen {
		zephyr,console = &usart3;
		zephyr,shell-uart = &usart3;
		zephyr,dtcm = &dtcm;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan1;
	};

	leds: leds {
		compatible = "gpio-leds";

		/* PB0 remapped to fpga-ctrl1; green LED unavailable */

		yellow_led: led_1 {
			gpios = <&gpioe 1 GPIO_ACTIVE_HIGH>;
			label = "User LD2";
		};

		red_led: led_2 {
			gpios = <&gpiob 14 GPIO_ACTIVE_HIGH>;
			label = "User LD3";
		};
	};

	afe_manager: afe_manager {
		compatible = "gpio-leds";
		status = "okay";

		attenuation_ch1: attenuation_ch1 {
			gpios = <&gpiof 7 GPIO_ACTIVE_HIGH>;
			label = "AFE_ATTENUATION_CH1";
		};

		attenuation_ch2: attenuation_ch2 {
			gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>;
			label = "AFE_ATTENUATION_CH2";
		};

		coupling_ch1: coupling_ch1 {
			gpios = <&gpiob 4 GPIO_ACTIVE_HIGH>;
			label = "AFE_COUPLING_CH1";
		};

		coupling_ch2: coupling_ch2 {
			gpios = <&gpioc 7 GPIO_ACTIVE_HIGH>;
			label = "AFE_COUPLING_CH2";
		};

		coupling_trigger: coupling_trigger {
			gpios = <&gpioa 0 GPIO_ACTIVE_HIGH>;
			label = "AFE_COUPLING_TRIGGER";
		};

		interleaved: interleaved {
			gpios = <&gpiog 0 GPIO_ACTIVE_HIGH>;
			label = "AFE_INTERLEAVED";
		};
	};

	pwmleds {
		compatible = "pwm-leds";

		red_pwm_led: red_pwm_led {
			pwms = <&pwm12 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "User LD3 - PWM12";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_button: button_0 {
			label = "User";
			gpios = <&gpioc 13 GPIO_ACTIVE_HIGH>;
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	aliases {
		led0 = &yellow_led;
		led2 = &red_led;
		pwm-led0 = &red_pwm_led;
		sw0 = &user_button;
		dac0 = &spi_dac61408;

        /* MCU → FPGA: CTRL bus (8 pins, [2:0]=OP, [7:3]=PAYLOAD) */
        fpga-ctrl0 = &fpga_ctrl0_node;
        fpga-ctrl1 = &fpga_ctrl1_node;
        fpga-ctrl2 = &fpga_ctrl2_node;
        fpga-ctrl3 = &fpga_ctrl3_node;
        fpga-ctrl4 = &fpga_ctrl4_node;
        fpga-ctrl5 = &fpga_ctrl5_node;
        fpga-ctrl6 = &fpga_ctrl6_node;
        fpga-ctrl7 = &fpga_ctrl7_node;

        /* MCU → FPGA: direction and strobe */
        fpga-rw     = &fpga_rw_node;
        fpga-req    = &fpga_req_node;

        /* FPGA → MCU: DATA bus (14 pins) */
        fpga-data0  = &fpga_data0_node;
        fpga-data1  = &fpga_data1_node;
        fpga-data2  = &fpga_data2_node;
        fpga-data3  = &fpga_data3_node;
        fpga-data4  = &fpga_data4_node;
        fpga-data5  = &fpga_data5_node;
        fpga-data6  = &fpga_data6_node;
        fpga-data7  = &fpga_data7_node;
        fpga-data8  = &fpga_data8_node;
        fpga-data9  = &fpga_data9_node;
        fpga-data10 = &fpga_data10_node;
        fpga-data11 = &fpga_data11_node;
        fpga-data12 = &fpga_data12_node;
        fpga-data13 = &fpga_data13_node;

        /* FPGA → MCU: handshake and interrupt */
        fpga-ack    = &fpga_ack_node;
        fpga-irq    = &fpga_irq_node;
	};

	fpga_parallel: fpga_parallel {
		compatible = "gpio-leds";
		status = "okay";

		/* CTRL bus — outputs */
		fpga_ctrl0_node: fpga-ctrl0 { gpios = <&gpiob 11 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl1_node: fpga-ctrl1 { gpios = <&gpiob 0 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl2_node: fpga-ctrl2 { gpios = <&gpioe 14 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl3_node: fpga-ctrl3 { gpios = <&gpiod 2 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl4_node: fpga-ctrl4 { gpios = <&gpiod 15 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl5_node: fpga-ctrl5 { gpios = <&gpioe 9 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl6_node: fpga-ctrl6 { gpios = <&gpioe 11 GPIO_ACTIVE_HIGH>; };
		fpga_ctrl7_node: fpga-ctrl7 { gpios = <&gpioe 13 GPIO_ACTIVE_HIGH>; };

		fpga_rw_node:  fpga-rw  { gpios = <&gpioe 8 GPIO_ACTIVE_HIGH>; };
		fpga_req_node: fpga-req { gpios = <&gpioe 7 GPIO_ACTIVE_HIGH>; };

		/* DATA bus — inputs */
		fpga_data0_node:  fpga-data0  { gpios = <&gpiof 1 GPIO_ACTIVE_HIGH>; };
		fpga_data1_node:  fpga-data1  { gpios = <&gpiof 0 GPIO_ACTIVE_HIGH>; };
		fpga_data2_node:  fpga-data2  { gpios = <&gpioe 6 GPIO_ACTIVE_HIGH>; };
		fpga_data3_node:  fpga-data3  { gpios = <&gpioe 5 GPIO_ACTIVE_HIGH>; };
		fpga_data4_node:  fpga-data4  { gpios = <&gpioe 4 GPIO_ACTIVE_HIGH>; };
		fpga_data5_node:  fpga-data5  { gpios = <&gpiod 3 GPIO_ACTIVE_HIGH>; };
		fpga_data6_node:  fpga-data6  { gpios = <&gpiod 4 GPIO_ACTIVE_HIGH>; };
		fpga_data7_node:  fpga-data7  { gpios = <&gpiod 5 GPIO_ACTIVE_HIGH>; };
		fpga_data8_node:  fpga-data8  { gpios = <&gpiod 6 GPIO_ACTIVE_HIGH>; };
		fpga_data9_node:  fpga-data9  { gpios = <&gpioe 10 GPIO_ACTIVE_HIGH>; };
		fpga_data10_node: fpga-data10 { gpios = <&gpioe 0 GPIO_ACTIVE_HIGH>; };
		fpga_data11_node: fpga-data11 { gpios = <&gpioe 15 GPIO_ACTIVE_HIGH>; };
		fpga_data12_node: fpga-data12 { gpios = <&gpioe 2 GPIO_ACTIVE_HIGH>; };
		fpga_data13_node: fpga-data13 { gpios = <&gpioe 12 GPIO_ACTIVE_HIGH>; };

		fpga_ack_node: fpga-ack { gpios = <&gpiob 6 GPIO_ACTIVE_HIGH>; };
		fpga_irq_node: fpga-irq { gpios = <&gpiob 7 GPIO_ACTIVE_HIGH>; };
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&clk_hse {
	hse-bypass;
	clock-frequency = <DT_FREQ_M(8)>; /* STLink 8MHz clock */
	status = "okay";
};

&clk_lse {
	status = "okay";
};

&pll {
	div-m = <4>;
	mul-n = <275>;
	div-p = <1>;
	div-q = <4>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&pll2 {
	div-m = <1>;
	mul-n = <10>;
	div-p = <1>;
	div-q = <1>;
	div-r = <1>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(550)>;
	d1cpre = <1>;
	hpre = <2>;    /* HCLK: 275   MHz */
	d1ppre = <2>;  /* APB1: 137.5 MHz */
	d2ppre1 = <2>; /* APB2: 137.5 MHz */
	d2ppre2 = <2>; /* APB3: 137.5 MHz */
	d3ppre = <2>;  /* APB4: 137.5 MHz */
};

&lpuart1 {
	pinctrl-0 = <&lpuart1_tx_pb6 &lpuart1_rx_pb7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled"; /* PB6/PB7 used by fpga-ack/fpga-irq */
};

&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "disabled"; /* PD5/PD6 used by fpga-data7/fpga-data8 */
};

&rtc {
	clocks = <&rcc STM32_CLOCK_BUS_APB4 0x00010000>,
		 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
	status = "okay";
};

&spi1 {
	status = "okay";
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pb5>;
	pinctrl-names = "default";
	cs-gpios = <&gpiod 14 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

	spi_dac61408: dac61408@0 {
		compatible = "ti,dac61408";
		status = "okay";

		reg = <0x0>;

		clr-gpios = <&gpiof 9  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		reset-gpios = <&gpiof 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

		spi-max-frequency = <1000000>;
		spi-cpha;
		#io-channel-cells = <1>;
		
		voltage-reference = <0>;
		channel-gains = <0 0 0 0 0 0 0 0>;
	};
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
};

&backup_sram {
	status = "okay";
};

&timers12 {
	st,prescaler = <10000>;
	status = "okay";

	pwm12: pwm {
		status = "okay";
		pinctrl-0 = <&tim12_ch1_pb14>;
		pinctrl-names = "default";
	};
};

&mac {
	status = "okay";
	pinctrl-0 = <&eth_ref_clk_pa1
		     &eth_crs_dv_pa7
		     &eth_rxd0_pc4
		     &eth_rxd1_pc5
		     &eth_tx_en_pg11
		     &eth_txd0_pg13
		     &eth_txd1_pb13>;
	pinctrl-names = "default";
	phy-connection-type = "rmii";
	phy-handle = <&eth_phy>;
};

&mdio {
	status = "okay";
	pinctrl-0 = <&eth_mdio_pa2 &eth_mdc_pc1>;
	pinctrl-names = "default";

	eth_phy: ethernet-phy@0 {
		compatible = "ethernet-phy";
		reg = <0>;
	};
};

zephyr_udc0: &usbotg_hs {
	pinctrl-0 = <&usb_otg_hs_dm_pa11 &usb_otg_hs_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};

&rng {
	status = "okay";
};

